# Gurukul AI Configuration
# 1. Get your API Key from https://aistudio.google.com/app/apikey
# 2. Invert (Base64 Encode) your key. 
#    You can use: echo -n "YOUR_API_KEY" | base64 (on Linux/Mac)
#    Or an online tool.
# 3. Paste the inverted key below and rename this file to .env

INVERTED_GEMINI_KEY=YOUR_BASE64_ENCODED_KEY_HERE

# Published lesson JSON (local dev — served from /published/Grade_6)
CONTENT_BASE_URL=http://localhost:3000/published/Grade_6
